rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user owns the data
    function isOwner() {
      return request.auth.uid == resource.data.usuarioId;
    }
    
    // Regras para a coleção de usuários
    match /usuarios/{userId} {
      // Apenas administradores podem ler e escrever dados de usuários
      allow read, write: if request.auth != null && isAdmin();
    }
    
    // Regras para clientes - usuários veem seus dados, admin vê todos
    match /clientes/{clienteId} {
      allow read, write: if request.auth != null && (isOwner() || isAdmin());
      allow create: if request.auth != null && request.resource.data.usuarioId == request.auth.uid;
    }
    
    // Regras para planos - usuários veem seus dados, admin vê todos
    match /planos/{planoId} {
      allow read, write: if request.auth != null && (isOwner() || isAdmin());
      allow create: if request.auth != null && request.resource.data.usuarioId == request.auth.uid;
    }
    
    // Regras para recebimentos - usuários veem seus dados, admin vê todos
    match /recebimentos/{recebimentoId} {
      allow read, write: if request.auth != null && (isOwner() || isAdmin());
      allow create: if request.auth != null && request.resource.data.usuarioId == request.auth.uid;
    }
    
    // Regras para despesas - usuários veem seus dados, admin vê todos
    match /despesas/{despesaId} {
      allow read, write: if request.auth != null && (isOwner() || isAdmin());
      allow create: if request.auth != null && request.resource.data.usuarioId == request.auth.uid;
    }
    
    // Regras para mensalidades - usuários veem seus dados, admin vê todos
    match /mensalidades/{mensalidadeId} {
      allow read, write: if request.auth != null && (isOwner() || isAdmin());
      allow create: if request.auth != null && request.resource.data.usuarioId == request.auth.uid;
    }
    
    // Regras para histórico do WhatsApp - usuários veem seus dados, admin vê todos
    match /whatsapp_historico/{historicoId} {
      allow read, write: if request.auth != null && (isOwner() || isAdmin());
      allow create: if request.auth != null && request.resource.data.usuarioId == request.auth.uid;
    }
    
    // Regras para configurações do WhatsApp - usuários veem suas configurações, admin vê todas
    match /configuracoes/whatsapp {
      allow read, write: if request.auth != null;
    }
    
    // Regras para configurações do sistema - apenas admin
    match /configuracoes/sistema {
      allow read, write: if request.auth != null && isAdmin();
    }
    
    // Regras para auditoria - apenas admin pode ler, usuários podem escrever
    match /auditoria/{auditoriaId} {
      allow create: if request.auth != null && request.resource.data.usuarioId == request.auth.uid;
      allow read: if request.auth != null && isAdmin();
      allow update, delete: if false;
    }
    
    // Regras para backups - apenas admin
    match /backups/{backupId} {
      allow read, write: if request.auth != null && isAdmin();
    }
    
  }
}
