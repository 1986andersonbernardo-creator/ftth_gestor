rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getTenantId() {
      return request.auth.token.tenantId ? request.auth.token.tenantId : request.auth.uid;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'MASTER_ADMIN' ||
        request.auth.token.role == 'superadmin'
      );
    }

    function ownsDoc() {
      return isSignedIn() && resource.data.tenantId == getTenantId();
    }

    function ownsNewDoc() {
      return isSignedIn() && request.resource.data.tenantId == getTenantId();
    }

    match /usuarios/{userId} {
      allow read: if isSuperAdmin() || request.auth.uid == userId;
      allow create: if isSuperAdmin() || (request.auth.uid == userId 
        && request.resource.data.uid == request.auth.uid);
      allow update: if isSuperAdmin() || request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    match /empresas/{empresaId} {
      allow read: if isSuperAdmin() || empresaId == getTenantId();
      allow create: if isSuperAdmin() || (empresaId == getTenantId() && isSignedIn());
      allow update: if isSuperAdmin() || empresaId == getTenantId();
      allow delete: if isSuperAdmin();
    }

    match /planos_sa/{planoId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /clientes/{clienteId} {
      allow read: if isSuperAdmin() || ownsDoc();
      allow create: if isSuperAdmin() || ownsNewDoc();
      allow update: if isSuperAdmin() || ownsDoc();
      allow delete: if isSuperAdmin() || ownsDoc();
    }

    match /planos/{planoId} {
      allow read: if isSuperAdmin() || ownsDoc();
      allow create: if isSuperAdmin() || ownsNewDoc();
      allow update: if isSuperAdmin() || ownsDoc();
      allow delete: if isSuperAdmin() || ownsDoc();
    }

    match /recebimentos/{recebimentoId} {
      allow read: if isSuperAdmin() || ownsDoc();
      allow create: if isSuperAdmin() || ownsNewDoc();
      allow update: if isSuperAdmin() || ownsDoc();
      allow delete: if isSuperAdmin() || ownsDoc();
    }

    match /despesas/{despesaId} {
      allow read: if isSuperAdmin() || ownsDoc();
      allow create: if isSuperAdmin() || ownsNewDoc();
      allow update: if isSuperAdmin() || ownsDoc();
      allow delete: if isSuperAdmin() || ownsDoc();
    }

    match /mensalidades/{mensalidadeId} {
      allow read: if isSuperAdmin() || ownsDoc();
      allow create: if isSuperAdmin() || ownsNewDoc();
      allow update: if isSuperAdmin() || ownsDoc();
      allow delete: if isSuperAdmin() || ownsDoc();
    }

    match /whatsapp_historico/{historicoId} {
      allow read: if isSuperAdmin() || ownsDoc();
      allow create: if isSuperAdmin() || ownsNewDoc();
      allow update, delete: if isSuperAdmin();
    }

    match /configuracoes/{configId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /auditoria/{auditoriaId} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /auditLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /providers/{providerId} {
      allow read: if isSuperAdmin() || providerId == getTenantId();
      allow create: if isSuperAdmin() || (request.resource.data.tenantId == getTenantId() 
        && providerId == getTenantId());
      allow update: if isSuperAdmin() || providerId == getTenantId();
      allow delete: if isSuperAdmin();
    }

    match /backups/{backupId} {
      allow read, write: if isSuperAdmin() || ownsDoc();
    }

    match /sessions/{sessionId} {
      allow read, write: if isSuperAdmin();
    }
  }
}