rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Get tenantId from auth claims or fallback to uid
    function getTenantId() {
      return request.auth.token.tenantId ? request.auth.token.tenantId : request.auth.uid;
    }

    // Check if the document belongs to the user's tenant
    function ownsDoc() {
      return isSignedIn() && resource.data.tenantId == getTenantId();
    }

    // Check if the new document belongs to the user's tenant
    function ownsNewDoc() {
      return isSignedIn() && request.resource.data.tenantId == getTenantId();
    }

    // ===== USUARIOS =====
    match /usuarios/{userId} {
      allow read: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId 
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth.uid == userId;
      allow delete: if false;
    }

    // ===== TENANT-SCOPED COLLECTIONS =====
    match /clientes/{clienteId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update: if ownsDoc();
      allow delete: if ownsDoc();
    }

    match /planos/{planoId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update: if ownsDoc();
      allow delete: if ownsDoc();
    }

    match /recebimentos/{recebimentoId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update: if ownsDoc();
      allow delete: if ownsDoc();
    }

    match /despesas/{despesaId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update: if ownsDoc();
      allow delete: if ownsDoc();
    }

    match /mensalidades/{mensalidadeId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update: if ownsDoc();
      allow delete: if ownsDoc();
    }

    match /whatsapp_historico/{historicoId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update, delete: if false;
    }

    // ===== CONFIGURAÇÕES =====
    match /configuracoes/{configId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.token.role == 'MASTER_ADMIN' || ownsDoc());
    }

    // ===== AUDITORIA =====
    match /auditoria/{auditoriaId} {
      allow create: if ownsNewDoc();
      allow read: if ownsDoc();
      allow update, delete: if false;
    }

    // ===== BACKUPS =====
    match /backups/{backupId} {
      allow read, write: if isSignedIn() && (request.auth.token.role == 'MASTER_ADMIN' || ownsDoc());
    }
  }
}